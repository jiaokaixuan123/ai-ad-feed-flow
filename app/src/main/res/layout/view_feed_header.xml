<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/feed_background"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding"
    android:paddingTop="@dimen/home_header_padding_top"
    android:paddingEnd="@dimen/screen_padding"
    android:paddingBottom="@dimen/home_header_padding_bottom">

    <TextView
        android:id="@+id/home_badge_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_badge"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="@string/home_badge"
        android:textColor="@color/feed_accent"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/home_title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/home_title"
        android:textColor="@color/feed_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/home_subtitle_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/home_subtitle"
        android:textColor="@color/feed_text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/search_entry"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_search_height"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_home_search"
        android:clickable="true"
        android:contentDescription="@string/content_desc_search_entry"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="@dimen/home_action_icon_size"
            android:layout_height="@dimen/home_action_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_search"
            app:tint="@color/feed_text_secondary" />

        <TextView
            android:id="@+id/search_hint_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="@string/home_search_hint"
            android:textColor="@color/feed_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/search_ai_badge_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_ai_badge"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="@string/home_search_ai_badge"
            android:textColor="@color/feed_accent"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/interactions_entry"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/home_action_button_size"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_home_interactions"
        android:clickable="true"
        android:contentDescription="@string/content_desc_interactions_entry"
        android:drawableStart="@drawable/ic_bookmark"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/home_interactions_label"
        android:textColor="@color/feed_data"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
